{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://syntechrev.com/schemas/legal_schema.json",
  "title": "Canonical Legal Document Schema",
  "description": "Normalized schema for legislative, contractual, and administrative documents",
  "type": "object",
  "required": ["document_id", "title", "document_type", "provenance"],
  "properties": {
    "document_id": {
      "type": "string",
      "description": "Unique identifier for the document",
      "pattern": "^[a-z0-9\\-]+$"
    },
    "title": {
      "type": "string",
      "description": "Official title of the document"
    },
    "document_type": {
      "type": "string",
      "description": "Type of legal document",
      "enum": ["act", "bill", "regulation", "executive_order", "contract", "amendment", "repeal"]
    },
    "sections": {
      "type": "array",
      "description": "Structured sections of the document",
      "items": {
        "type": "object",
        "required": ["section_id", "content"],
        "properties": {
          "section_id": {
            "type": "string",
            "description": "Section identifier (e.g., 'Section 1', 'Article II')"
          },
          "title": {
            "type": "string",
            "description": "Section title or heading"
          },
          "content": {
            "type": "string",
            "description": "Section text content"
          }
        }
      }
    },
    "authority": {
      "type": "string",
      "description": "Issuing authority or legislative body"
    },
    "jurisdiction": {
      "type": "string",
      "description": "Geographical or organizational jurisdiction"
    },
    "version_date": {
      "type": "string",
      "format": "date-time",
      "description": "Effective date or version timestamp (ISO 8601)"
    },
    "signatory": {
      "type": "array",
      "description": "List of signatories or authorized parties",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "signature_date": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "provenance": {
      "type": "object",
      "required": ["source", "hash", "verified_on"],
      "description": "Provenance and integrity metadata",
      "properties": {
        "source": {
          "type": "string",
          "description": "Original source URL or identifier"
        },
        "hash": {
          "type": "string",
          "description": "SHA-256 hash of the document content"
        },
        "verified_on": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of verification (ISO 8601)"
        }
      }
    },
    "references": {
      "type": "array",
      "description": "Cross-references to other documents",
      "items": {
        "type": "object",
        "properties": {
          "document_id": {
            "type": "string",
            "description": "Referenced document ID"
          },
          "reference_type": {
            "type": "string",
            "enum": ["cites", "amends", "repeals", "supersedes", "implements"],
            "description": "Type of reference relationship"
          },
          "section": {
            "type": "string",
            "description": "Specific section referenced"
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "description": "Additional metadata",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["draft", "active", "repealed", "superseded"],
          "description": "Current status of the document"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Categorization tags"
        },
        "notes": {
          "type": "string",
          "description": "Additional notes or annotations"
        }
      }
    }
  }
}
