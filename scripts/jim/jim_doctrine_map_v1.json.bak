{
  "version": "1.1.0",
  "description": "Doctrinal framework mapping for Judicial Interpretive Matrix - CLEP-v1 Enhanced",
  "doctrines": {
    "due_process": {
      "name": "Due Process",
      "constitutional_basis": [
        "Fifth Amendment",
        "Fourteenth Amendment"
      ],
      "key_principles": [
        "Procedural due process requires notice and hearing",
        "Substantive due process protects fundamental rights",
        "Mathews v. Eldridge balancing test applies"
      ],
      "triggers": [
        "Deprivation of life, liberty, or property",
        "Government benefit termination",
        "Administrative sanctions",
        "Inadequate notice or hearing"
      ],
      "weight": 0.95
    },
    "non_delegation": {
      "name": "Non-Delegation Doctrine",
      "constitutional_basis": [
        "Article I, Section 1"
      ],
      "key_principles": [
        "Congress cannot delegate legislative power",
        "Intelligible principle required for delegation",
        "Standards must guide agency discretion"
      ],
      "triggers": [
        "Broad agency discretion without standards",
        "Lack of policy guidance in statute",
        "Unfettered executive authority"
      ],
      "weight": 0.9
    },
    "separation_of_powers": {
      "name": "Separation of Powers",
      "constitutional_basis": [
        "Article I",
        "Article II",
        "Article III"
      ],
      "key_principles": [
        "Powers divided among three branches",
        "No branch may encroach on another",
        "Checks and balances preserved"
      ],
      "triggers": [
        "Executive overreach into legislative domain",
        "Judicial functions delegated to executive",
        "Cross-agency jurisdiction conflicts"
      ],
      "weight": 0.92
    },
    "fourth_amendment": {
      "name": "Fourth Amendment Privacy",
      "constitutional_basis": [
        "Fourth Amendment"
      ],
      "key_principles": [
        "Protection against unreasonable searches",
        "Warrant requirement with probable cause",
        "Reasonable expectation of privacy",
        "Special needs exception narrowly construed"
      ],
      "triggers": [
        "Surveillance programs",
        "Warrantless searches",
        "Digital data collection",
        "Location tracking"
      ],
      "weight": 0.95
    },
    "equal_protection": {
      "name": "Equal Protection",
      "constitutional_basis": [
        "Fourteenth Amendment"
      ],
      "key_principles": [
        "Similarly situated persons treated similarly",
        "Rational basis for distinctions",
        "Heightened scrutiny for suspect classifications",
        "Class-of-one protection"
      ],
      "triggers": [
        "Arbitrary discrimination",
        "Disparate treatment without justification",
        "Selective enforcement"
      ],
      "weight": 0.85
    },
    "administrative_law": {
      "name": "Administrative Law",
      "constitutional_basis": [
        "Article I",
        "Article II",
        "Administrative Procedure Act"
      ],
      "key_principles": [
        "Reasoned decision-making required",
        "Arbitrary and capricious standard",
        "Substantial evidence for findings",
        "Notice and comment for rulemaking",
        "Independent judicial review"
      ],
      "triggers": [
        "Inadequate explanation for agency action",
        "Failure to consider relevant factors",
        "Departure from prior practice without justification",
        "Procedural irregularities"
      ],
      "weight": 0.9,
      "note": "Post-Loper Bright (2024): Courts exercise independent judgment on statutory interpretation without agency deference"
    },
    "unconstitutional_conditions": {
      "name": "Unconstitutional Conditions Doctrine",
      "constitutional_basis": [
        "First Amendment",
        "Due Process Clause"
      ],
      "key_principles": [
        "Government cannot condition benefits on surrender of rights",
        "Coercion of constitutional rights prohibited",
        "Voluntary acceptance must be genuine"
      ],
      "triggers": [
        "Benefit conditioned on waiver of rights",
        "Compelled speech or association",
        "Forced surrender of constitutional protections"
      ],
      "weight": 0.8
    },
    "constitutional_torts": {
      "name": "Constitutional Torts and Qualified Immunity",
      "constitutional_basis": [
        "42 U.S.C. \u00a7 1983",
        "Bivens Actions",
        "Fourth Amendment",
        "Due Process"
      ],
      "key_principles": [
        "Government officials liable for constitutional violations",
        "Qualified immunity protects unless clearly established law violated",
        "Objective reasonableness standard for official conduct",
        "Remedy for deprivation of federal rights under color of law"
      ],
      "triggers": [
        "Government official misconduct",
        "Violation of clearly established rights",
        "Excessive force or unlawful detention",
        "Administrative overreach causing injury"
      ],
      "weight": 0.82
    },
    "property_rights": {
      "name": "Property Rights and Economic Liberty",
      "constitutional_basis": [
        "Fifth Amendment Takings",
        "Fourteenth Amendment Due Process",
        "Contract Clause"
      ],
      "key_principles": [
        "Property includes tangible and intangible interests",
        "Government takings require just compensation",
        "Substantive due process protects against arbitrary deprivation",
        "Liberty interests include contractual freedom"
      ],
      "triggers": [
        "Government taking without compensation",
        "Arbitrary interference with property or contracts",
        "Regulatory restrictions on economic activity",
        "Vendor contract interference"
      ],
      "weight": 0.78
    },
    "free_movement": {
      "name": "Right to Travel and Freedom of Movement",
      "constitutional_basis": [
        "Fourteenth Amendment Privileges and Immunities",
        "Equal Protection",
        "Due Process"
      ],
      "key_principles": [
        "Right to interstate travel is fundamental",
        "Durational residency requirements require compelling interest",
        "New residents entitled to equal treatment",
        "Identity control measures must not burden fundamental rights"
      ],
      "triggers": [
        "Durational residency requirements",
        "Restrictions on interstate migration",
        "Identity control or tracking systems",
        "Differential treatment based on residency status"
      ],
      "weight": 0.84
    }
  },
  "interpretive_frameworks": {
    "major_questions_doctrine": {
      "name": "Major Questions Doctrine",
      "description": "Agency must have clear congressional authorization for decisions of vast economic and political significance",
      "applicable_when": [
        "Vast economic impact",
        "Political significance",
        "Transformative regulatory action",
        "Novel assertion of authority"
      ],
      "standard": "Clear congressional authorization required",
      "weight": 0.95
    },
    "clear_statement_rule": {
      "name": "Clear Statement Rule",
      "description": "Congress must clearly state intent when affecting fundamental rights or federal-state balance",
      "applicable_when": [
        "Fundamental rights implicated",
        "Federalism concerns",
        "Extraterritorial application",
        "Retroactive legislation"
      ],
      "standard": "Plain statement of congressional intent required",
      "weight": 0.9
    },
    "chevron_deference": {
      "name": "Chevron Deference (Overruled 2024)",
      "description": "Courts defer to reasonable agency interpretation of ambiguous statute",
      "status": "OVERRULED by Loper Bright Enterprises v. Raimondo (2024)",
      "replacement": "Courts now exercise independent judgment on all statutory questions",
      "weight": 0.0,
      "historical_note": "Prior to 2024, Chevron provided two-step framework: (1) Is statute ambiguous? (2) Is agency interpretation reasonable?"
    },
    "auer_deference": {
      "name": "Auer/Seminole Rock Deference",
      "description": "Agency interpretation of own regulation entitled to deference unless plainly erroneous",
      "status": "LIMITED",
      "applicable_when": [
        "Genuine ambiguity in regulation",
        "Interpretation reflects fair reading",
        "Not post hoc rationalization",
        "Not convenience of litigating position"
      ],
      "weight": 0.6,
      "note": "Subject to limitations from Kisor v. Wilkie (2019)"
    },
    "rule_of_lenity": {
      "name": "Rule of Lenity",
      "description": "Ambiguous criminal statutes construed in favor of defendant",
      "applicable_when": [
        "Criminal penalty statute",
        "Civil penalty with quasi-criminal nature",
        "Ambiguity remains after interpretation"
      ],
      "standard": "Reasonable doubt resolved in favor of defendant",
      "weight": 0.85
    },
    "constitutional_avoidance": {
      "name": "Constitutional Avoidance Canon",
      "description": "Interpret statutes to avoid constitutional questions",
      "applicable_when": [
        "Multiple plausible interpretations",
        "One interpretation raises constitutional doubt",
        "Another interpretation avoids doubt"
      ],
      "standard": "Choose interpretation avoiding constitutional problems",
      "weight": 0.88
    },
    "digital_privacy_protection": {
      "name": "Digital Privacy Protection Framework",
      "description": "Modern Fourth Amendment protection for digital information and electronic communications",
      "applicable_when": [
        "Cell phone or digital device searches",
        "Location tracking or cell-site data",
        "Electronic communications surveillance",
        "Database queries without warrant"
      ],
      "standard": "Warrant generally required absent exigent circumstances or valid exception",
      "weight": 0.92,
      "related_cases": [
        "carpenter_v_us_2018",
        "riley_v_california_2014",
        "us_v_jones_2012"
      ]
    },
    "chain_of_custody_integrity": {
      "name": "Chain of Custody and Evidence Integrity",
      "description": "Fruit of poisonous tree doctrine and evidentiary integrity requirements",
      "applicable_when": [
        "Evidence derived from illegal search or seizure",
        "Documentary integrity questioned",
        "Metadata or timestamp conflicts",
        "Gaps in custody documentation"
      ],
      "standard": "Evidence inadmissible if fruit of constitutional violation unless independent source or attenuation",
      "weight": 0.88,
      "related_cases": [
        "silverthorne_lumber_v_united_states_1920",
        "nardone_v_united_states_1939",
        "wong_sun_v_united_states_1963"
      ]
    },
    "police_accountability": {
      "name": "Police Accountability and Use of Force",
      "description": "Fourth Amendment reasonableness standard for use of force and qualified immunity limits",
      "applicable_when": [
        "Excessive force allegations",
        "Deadly force incidents",
        "Qualified immunity defenses",
        "Law enforcement misconduct"
      ],
      "standard": "Objective reasonableness from perspective of officer on scene; qualified immunity unless clearly established law violated",
      "weight": 0.9,
      "related_cases": [
        "graham_v_connor_1989",
        "tennessee_v_garner_1985"
      ]
    }
  }
}