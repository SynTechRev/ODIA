  "interpretive_canon_definitions": {
    "rule_of_lenity": {
      "name": "Rule of Lenity",
      "description": "Ambiguous penal or regulatory statutes construed in favor of regulated party",
      "application": "Apply when statute imposes penalties and ambiguity persists",
      "constitutional_basis": "Due Process Clause (fair notice)",
      "weight": 0.85
    },
    "major_questions_doctrine": {
      "name": "Major Questions Doctrine",
      "description": "Agency must have clear congressional authorization for decisions of vast economic/political significance",
      "application": "Transformative regulatory actions, novel assertions of authority, vast economic impact",
      "constitutional_basis": "Article I (non-delegation), separation of powers",
      "weight": 0.95,
      "key_case": "West Virginia v. EPA (2022)"
    },
    "clear_statement_rule": {
      "name": "Clear Statement Rule",
      "description": "Congress must clearly state intent when affecting fundamental rights, federalism, or extraterritoriality",
      "application": "Fundamental rights, federal-state balance, retroactive laws",
      "constitutional_basis": "Various constitutional provisions",
      "weight": 0.90,
      "key_case": "Kent v. Dulles (1958)"
    },
    "constitutional_avoidance": {
      "name": "Constitutional Avoidance Canon",
      "description": "Interpret statutes to avoid serious constitutional questions",
      "application": "Choose interpretation that avoids constitutional doubt",
      "constitutional_basis": "Judicial restraint, constitutional supremacy",
      "weight": 0.88
    },
    "non_delegation": {
      "name": "Non-Delegation Canon",
      "description": "Statutes construed to contain intelligible principle guiding agency discretion",
      "application": "Broad delegations require limiting construction",
      "constitutional_basis": "Article I, Section 1 (vesting clause)",
      "weight": 0.90,
      "key_cases": ["Schechter Poultry (1935)", "Gundy v. US (2019)"]
    },
    "substantive_due_process": {
      "name": "Substantive Due Process Protection",
      "description": "Statutes affecting fundamental rights receive heightened scrutiny",
      "application": "Liberty, property, fundamental rights",
      "constitutional_basis": "Fifth/Fourteenth Amendment Due Process",
      "weight": 0.92
    },
    "equal_protection_scrutiny": {
