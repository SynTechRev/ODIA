LEXICON_GRAPH.json
LEXICON_STATS.json
LEXICON_SUMMARY.md

# Semantic Harmonization (MSH-v1) generated outputs at root
# These are generated by CI and should not be committed at root
/artifacts/SEMANTIC_HARMONIZATION_MATRIX.json
/artifacts/MEANING_DIVERGENCE_INDEX.json

