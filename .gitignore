# Generated corpus artifacts (do not commit large extracted text/metadata)
# Keep corpus structure, indexes, and reports; exclude per-file metadata and extracted text
oraculus/corpus/**/extracted/*.txt
oraculus/corpus/**/metadata/*.json
!oraculus/corpus/**/index.json
!oraculus/corpus/ingestion_report.json

# Large PDF files in corpus (handled via Git LFS or external storage)
oraculus/corpus/**/*.pdf
oraculus/corpus/**/*.PDF

# Ingestion and audit artifacts
ci_report.json

# Transient/temporary files from aborted runs
*.tmp
*.temp
.tmp/
tmp/

# Keep report files for tracking
!oraculus/corpus/audit_extension_report.json
!oraculus/corpus/missing_items_log.json

# ACE (Anomaly Correlation Engine) generated outputs at root
# These are generated by CI and should not be committed at root
/ACE_REPORT.json
/ACE_SUMMARY.md
/ANOMALY_MAP.csv
/ace_network_graph.json

# Vendor Influence & Contract Flow Map (VICFM) generated outputs at root
# These are generated by CI and should not be committed at root
/vendor_graph.json
/vendor_scores.json
/vendor_influence_network.csv
/vendor_index.json
/CONTRACT_FLOW_MAP.json
/CONTRACT_FLOW_MAP.md
/PROCUREMENT_FLAGS.json
/PROCUREMENT_FLAGS.md
/VENDOR_ANOMALY_LINKS.json
/VENDOR_TECH_DEPENDENCIES.json
/VENDOR_INFLUENCE_REPORT.md

# Allow analysis/ directory artifacts for plaintext audit generation
!analysis/ace/*.json
!analysis/ace/*.md
!analysis/ace/*.csv
!analysis/vendor/*.json
